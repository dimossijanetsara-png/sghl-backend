# ================================================================
#  SGHL Backend — Variables d'environnement
#  DEV : copiez ce fichier en .env et remplissez les valeurs
#  PROD (Render) : entrez ces clés dans Render > Environment
# ================================================================

# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ---- PRODUCTION RENDER : remplacez les valeurs ci-dessous ----
# DEBUG=False
# SECRET_KEY=une-cle-longue-aleatoire-50-caracteres-minimum
# ALLOWED_HOSTS=votre-service.onrender.com
# DATABASE_URL=  ← fournie automatiquement par Render PostgreSQL
# --------------------------------------------------------------

# Database (dev local)
DB_USE_SQLITE=False
DB_NAME=sghl_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis / Cache
CACHE_USE_REDIS=False
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=SGHL <noreply@sghl.com>

# Encryption
AES_ENCRYPTION_KEY=sghl-aes-256-key-change-in-prod!

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Application URLs
PATIENT_PORTAL_URL=http://localhost:3000
ADMIN_PORTAL_URL=http://localhost:5173
FRONTEND_URL=https://sghl-web.onrender.com

# Monitoring & Observability
SENTRY_DSN=
PROMETHEUS_METRICS_ENABLED=True

# File Upload
MAX_UPLOAD_SIZE=10485760

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Data Retention (days)
PATIENT_DATA_RETENTION_DAYS=2555
AUDIT_LOG_RETENTION_DAYS=365
SESSION_RETENTION_DAYS=30

# Geographic & Timezone
TIME_ZONE=Africa/Brazzaville
LANGUAGE_CODE=fr-fr
