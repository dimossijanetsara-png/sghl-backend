SECRET_KEY=django-insecure-dev-key-change-in-production-sghl-2026
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DB_USE_SQLITE=True
CACHE_USE_REDIS=False

# PostgreSQL
DB_NAME=sghl_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Email (SMTP Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=SGHL <your-email@gmail.com>

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Encryption (32 bytes)
AES_ENCRYPTION_KEY=sghl-aes-256-key-change-in-prod!
